{
  "name": "dicomweb-mcp-server",
  "version": "0.0.3",
  "description": "DICOMweb Model Context Protocol (MCP) server implementation",
  "type": "module",
  "scripts": {
    "build": "npm run lint && npm run webpack",
    "inspector": "npx @modelcontextprotocol/inspector node ./build/dicomweb-mcp-server.js",
    "lint": "eslint -c eslint.config.mjs --fix src && prettier --config prettier.config.mjs --write *.mjs src/**/*.js test/**/*.js",
    "test": "c8 --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --clean --reporter=text --reporter=html --include=src/**/*.js --exclude=src/index.js mocha test/**/*.test.js",
    "webpack": "webpack --progress --config webpack.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PantelisGeorgiadis/dicomweb-mcp-server.git"
  },
  "keywords": [
    "DICOM",
    "DICOMweb",
    "MCP"
  ],
  "author": "Pantelis Georgiadis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PantelisGeorgiadis/dicomweb-mcp-server/issues"
  },
  "homepage": "https://github.com/PantelisGeorgiadis/dicomweb-mcp-server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "mocha": "^11.7.5",
    "prettier": "^3.5.3",
    "terser-webpack-plugin": "^5.6.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },  
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dicomweb-mcp-server": "./build/dicomweb-mcp-server.js"
  },
  "files": [
    "build/dicomweb-mcp-server.js",
    "build/.env"
  ]
}
