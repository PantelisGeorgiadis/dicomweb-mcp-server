# URL of the DICOMweb server
DICOMWEB_HOST=http://localhost:8042/dicom-web/

# Authentication method: basic, bearer, or none
DICOMWEB_AUTH=basic

# Basic authentication credentials
DICOMWEB_USER=orthanc
DICOMWEB_PASS=orthanc

# Bearer token for authentication
DICOMWEB_TOKEN=token

# Query timeout in milliseconds (optional, default: 30000)
DICOMWEB_TIMEOUT=30000
